# 构建目录
build/
cmake-build-*/

# 部署目录
output/

# 编译产物
*.o
*.a
*.so
*.dylib
*.exe

# CMake缓存
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# 编译数据库（可选，如果希望提交到git可以注释掉）
# compile_commands.json

# IDE文件（保留.vscode配置，但忽略用户特定设置）
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# 但保留公共配置文件
!.vscode/c_cpp_properties.json

# 配置文件（包含敏感信息）
config.json

# 数据文件（可选，根据需要取消注释）
# data/long_term_memory.json

# 日志文件
*.log
